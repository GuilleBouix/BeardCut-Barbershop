---
import "../global.css";
import type { Props } from '../types/layoutProps';

const {
    title = 'BeardCut | Barbershop',
    description = 'BeardCut Barbershop in Austin, Texas. Classic cuts, fades, beard design and premium grooming services. Book your appointment now.',
    lang = 'en-US',
    canonicalURL,
    noIndex = false
} = Astro.props as Props;

const resolvedCanonicalURL = canonicalURL ?? new URL(Astro.url.pathname, Astro.site ?? Astro.url).href;

const schemaData = {
    "@context": "https://schema.org",
    "@type": "HairSalon",
    "name": "BeardCut Barbershop",
    "image": "https://beardcut.vercel.app/images/logo.webp",
    "address": {
        "@type": "PostalAddress",
        "streetAddress": "412 Congress Ave",
        "addressLocality": "Austin",
        "addressRegion": "TX",
        "postalCode": "78701",
        "addressCountry": "US"
    },
    "telephone": "+1-512-555-0148",
    "email": "contact@beardcut.com",
    "priceRange": "$$",
    "openingHoursSpecification": [
        {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
            "opens": "09:00",
            "closes": "20:00"
        },
        {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": "Saturday",
            "opens": "09:00",
            "closes": "18:00"
        }
    ],
    "geo": {
        "@type": "GeoCoordinates",
        "latitude": "30.2672",
        "longitude": "-97.7431"
    },
    "url": "https://beardcut.vercel.app",
    "sameAs": []
};
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/images/favicon.ico" sizes="32x32" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		{noIndex ? (
			<meta name="robots" content="noindex, nofollow" />
		) : (
			<link rel="canonical" href={resolvedCanonicalURL} />
		)}
		
		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={resolvedCanonicalURL} />
		<meta property="og:image" content="https://beardcut.vercel.app/images/og-image.jpg" />
		<meta property="og:locale" content="en_US" />
		<meta property="og:site_name" content="BeardCut Barbershop" />
		
		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="https://beardcut.vercel.app/images/og-image.jpg" />
		
		<!-- Schema.org JSON-LD -->
		<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
		<title>{title}</title>
	</head>
	<body>
        <main>
            <slot />
        </main>
        <script src="../scripts/booking-redirect.ts"></script>
        <script src="../scripts/auth-nav.ts"></script>
	</body>
</html>

